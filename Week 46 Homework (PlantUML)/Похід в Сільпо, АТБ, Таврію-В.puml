@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false

class Покупець {
  + Ім'я: string
  - Прізвище: string
  - ПоБатькові: string
  - Готівка: decimal
  + Стать: string
  - Пам'ятьПродуктів: List<string>
  + ПригадатиПродукт(): string
  + ВідповістиНаДзвінок(): void
  + СкластиСписокПокупок(): List<string>
  + ПеревіритиАкції(): List<Акція>
  + ЗнятиГотівку(): decimal
  + ПорадитисяЗПродавцем(): string
  + ПоспілкуватисяВЧерзі(): void
  + ОплатитиПокупки(): bool
}

class "СписокУПам'яті" {
  - Продукти: List<string>
  - Пріоритет: int
  - СтанПам'яті: bool
  + Запам'ятати(): void
  + Пригадати(): List<string>
  + Забути(): void
  + КупитиХлібТаВоду(): bool
}

class ТелефоннийДзвінок {
  - Абонент: string
  - ДиктованіПродукти: List<string>
  + ПрийнятиДзвінок(): void
  + Зателефонувати(): void
  + ДодатиДоКошика(): void
}

class СписокПродуктів {
  - Текст: string
  + Записати(): void
  + Закреслити(): void
  + ПеревіритиЧек(): bool
}

class Продукт {
  - Назва: string
  - Категорія: string
  - Ціна: decimal
  - Кількість: int
  - Маса: double
  + ПеревіритиАкцію(): bool
  + ПорівнятиЦіни(): int
}

class Гаманець {
  - Готівка: decimal
  - Картки: List<string>
  - Бонуси: double
  + ПокластиГотівку(): void
  + РозрахуватисяГотівкою(): bool
  + ВикористатиБонуси(): bool
  + ОплатитиКарткою(): bool
}

class Акція {
  - Назва: string
  - Знижка: double
  - ДієДо: DateTime
  + ПеревіритиЦінники(): bool
  + ЗастосуватиНаКасі(): void
}

class Продавець {
  - Відділ: string
  + Проконсультувати(): string
  + ПорадитиАкцію(): Акція
}

class Ваги {
  - Покази: string
  + Зважити(): double
  + НадрукуватиЕтикетку(): string
}

abstract class Магазин {
  - Назва: string
  - Адреса: string
  - ГрафікРоботи: string
  - БонусніПрограми: string
  - СтатистикаЧерг: string
  + ШукатиАкції(): List<Акція>
  + ПеревіритиЧергу(): bool
}

class АТБ {
  + ОтриматиЗнижкуЗаКарткоюАТБ(): double
}

class Сільпо {
  + ОтриматиБалобонуси(): int
}

class ТавріяВ {
  + ОтриматиКлеверБонус(): double
}

class Кошик {
  - Продукти: List<Продукт>
  - ПриблизнаСума: decimal
  + ДодатиЗПамяті(): void
  + ДодатиЗДзвінка(): void
  + ДодатиЗАкції(): void
  + РозрахуватиСуму(): decimal
}

' === Зв’язки ===
Покупець "1" -- "1" "СписокУПам'яті" : тримає в голові
Покупець "1" --> "*" ТелефоннийДзвінок : отримує/здійснює
Покупець "1" --> "0..1" СписокПродуктів : іноді записує
Покупець "1" -- "1" Гаманець : має
Покупець "1" --> "*" Акція : полює на
Покупець "1" --> "*" Продавець : консультується з
Покупець "1" --> "*" Ваги : використовує
Покупець "1" --> "*" Магазин : відвідує
Покупець "1" -- "1" Кошик : наповнює

"СписокУПам'яті" --> Кошик : додає продукти в
ТелефоннийДзвінок --> Кошик : додає продукти в
Акція "1" --> "*" Продукт : стосується
Кошик "1" o-- "*" Продукт : містить
Продавець "*" -- "1" Магазин : працює в
Ваги "*" -- "1" Магазин : розташовані в

Магазин <|-- АТБ
Магазин <|-- Сільпо
Магазин <|-- ТавріяВ

note right of АТБ
  Адреса: вул. Євгена Танцюри, 30
  Картка АТБ: -5% + акції
end note

note right of Сільпо
  Адреса: вул. Євгена Танцюри, 51
  Власний Рахунок: балобонуси
end note

note right of ТавріяВ
  Адреса: вул. Іцхака Рабіна, 7
  КлеверБонус + свіжа виробка
end note

@enduml